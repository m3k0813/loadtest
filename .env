# Truve Load Test Environment Variables
# 복사하여 사용: cp .env.template .env
# 그리고 실제 값으로 수정하세요!

# ==================== API Gateway ====================
# TODO: Kubernetes Ingress 또는 VirtualService URL 확인
# kubectl get ingress -n default
# kubectl get virtualservice -n default
BASE_URL=https://gateway.truve.site

# ==================== 테스트 데이터 ====================
# TODO: 실제 데이터베이스에서 확인
# kubectl exec -it postgres-pod -- psql -U truve -d truve_db
#
# 공연 ID 조회:
# SELECT id, title FROM shows WHERE status='ACTIVE' LIMIT 5;
TEST_SHOW_ID=1

# 공연 회차 ID 조회:
# SELECT id, show_date FROM show_schedules WHERE show_id='show-12345' LIMIT 5;
TEST_SHOW_SCHEDULE_ID=1

# ==================== 인증 ====================
# TODO: 백엔드 팀에 문의하여 테스트 계정 생성 또는 JWT Secret 확인
# application.yml 참고: jwt.secret
JWT_SECRET=kt-cloud-tech-up-final-project-2026020201010101

# 테스트용 사용자 ID (UUID 형식)
TEST_USER_ID=51bac483-1ba7-4049-8ef2-a63b5cb3d9ce

# ==================== 좌석 범위 ====================
# TODO: 실제 좌석 ID 범위 확인
# SELECT MIN(id), MAX(id) FROM scheduled_seats WHERE show_schedule_id=123;
MIN_SEAT_ID=2009
MAX_SEAT_ID=3085

# ==================== 부하 테스트 설정 ====================
# 안전한 시작 값 (점진적으로 증가)
MAX_VUS=100
TEST_DURATION=5m
RAMP_UP_DURATION=2m

# ==================== k6 출력 설정 ====================
# JSON 파일로 저장
K6_OUT=json=results/test-results.json

# InfluxDB (선택사항)
# TODO: InfluxDB 설치되어 있는지 확인
# kubectl get svc -n monitoring | grep influxdb
# K6_OUT=influxdb=http://influxdb.monitoring.svc.cluster.local:8086/k6

# Prometheus Remote Write (선택사항)
# TODO: Prometheus 설치되어 있는지 확인
# kubectl get svc -n monitoring | grep prometheus
# K6_PROMETHEUS_RW_SERVER_URL=http://prometheus-operated.monitoring.svc.cluster.local:9090/api/v1/write

# ==================== Kubernetes ====================
# 네임스페이스
K8S_NAMESPACE=default

# 부하 테스트용 네임스페이스
LOAD_TEST_NAMESPACE=load-test

# ==================== 환경 선택 ====================
# local, staging, production
ENVIRONMENT=staging

# ==================== AWS 설정 (선택사항) ====================
# 결과를 S3에 업로드
# AWS_REGION=ap-northeast-2
# S3_BUCKET=truve-load-test-results
# S3_PREFIX=tests/$(date +%Y%m%d)

# ==================== 알림 설정 (선택사항) ====================
# Slack Webhook (테스트 완료 시 알림)
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/YOUR/WEBHOOK/URL

# ==================== 데이터베이스 접속 (테스트 데이터 조회용) ====================
# kubectl get secret postgres-secret -o jsonpath='{.data.password}' | base64 -d
# DB_HOST=postgres.default.svc.cluster.local
# DB_PORT=5432
# DB_NAME=truve_db
# DB_USER=truve
# DB_PASSWORD=your-db-password
