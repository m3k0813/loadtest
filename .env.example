# Truve Load Test Environment Variables
# Copy this file to .env and customize for your environment

# API Gateway URL
BASE_URL=https://gateway.truve.site

# Test Data
TEST_SHOW_ID=show-12345
TEST_SHOW_SCHEDULE_ID=123

# k6 Output Settings
K6_OUT=json=results/test-results.json
K6_PROMETHEUS_RW_SERVER_URL=http://prometheus-operated.monitoring.svc.cluster.local:9090/api/v1/write

# InfluxDB (Optional)
INFLUXDB_URL=http://influxdb.monitoring.svc.cluster.local:8086
INFLUXDB_DB=k6

# Test Configuration
K6_VUS=100
K6_DURATION=10m
K6_ITERATIONS=1000
